# ─── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # development | production

# ─── MySQL Database ──────────────────────────────────────────
# Requires MySQL Server installed and running locally.
# Recommended: MySQL Workbench (https://dev.mysql.com/downloads/workbench/)
#
# The backend will automatically:
#   1. Create the database if it doesn't exist
#   2. Run database/schema.sql to create all tables on startup
# You do NOT need to create the database manually in Workbench.

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here   # your MySQL root (or user) password
DB_NAME=storystream

# ─── JWT Authentication ───────────────────────────────────────
# Generate a strong random secret for production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────
# URL of your frontend (Vite default is 5173)
CLIENT_URL=http://localhost:5173
