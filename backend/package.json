{
  "name": "storystream-backend",
  "version": "1.0.0",
  "description": "StoryStream backend API — Twitter-like platform built with Node.js, Express, and MySQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:init": "mysql -u root -p < database/schema.sql",
    "db:seed": "mysql -u root -p storystream < database/seed.sql"
  },
  "keywords": ["nodejs", "expressjs", "mysql", "jwt", "bcrypt", "social-media"],
  "author": "StoryStream",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.9.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
